# Eveera Tiara E-commerce Platform - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Session Secret
# Generate a strong random string for production (e.g., use: openssl rand -base64 32)
SESSION_SECRET=your_session_secret_here_change_in_production

# Instructions:
# 1. Copy this file: cp .env.example .env (or copy .env.example .env on Windows)
# 2. Fill in your Supabase credentials from https://app.supabase.com
# 3. Generate a secure SESSION_SECRET for production
# 4. Never commit .env to git (it's already in .gitignore)
